{
  "expo": {
    "name": "Butter",
    "slug": "butter",
    "version": "1.4.7",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "scheme": "butter",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.butter.expensetracker",
      "buildNumber": "6"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5C45E",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "package": "com.butter.expensetracker",
      "versionCode": 6
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-sqlite",
        {
          "enableFTS": false,
          "useSQLCipher": false
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/Butterbear-Expense-Tracker"
    }
  }
}
